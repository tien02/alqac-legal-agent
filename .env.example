# Copy to .env and fill in real values.
# .env is git-ignored; .env.example is committed as a template.

# ALQAC API key — register at https://sites.google.com/view/alqac2026/home
ALQAC_API_KEY=alqac_REPLACE_ME

# Local llama.cpp endpoints (started by docker-compose.llamacpp.yml)
# GPU 0: Jackrong Qwen3.5-9B distill  → :8001
# GPU 1: Qwen3.5-9B base GGUF         → :8002
LLAMACPP_BASE_URL=http://localhost:8001/v1
LLAMACPP_API_KEY=local-dev-key
LLAMACPP_MODEL_NAME=jackrong-distill-9b

# HuggingFace token (only for gated models)
HF_TOKEN=

# Paths
ALQAC_DATA_DIR=./Data
ALQAC_RUNS_DIR=./runs
