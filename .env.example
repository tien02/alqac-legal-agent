# Copy to .env and fill in real values.
# .env is git-ignored; .env.example is committed as a template.

# ALQAC API key — register at https://sites.google.com/view/alqac2026/home
ALQAC_API_KEY=alqac_REPLACE_ME

# Local vLLM endpoint (started by docker-compose.vllm.yml)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=local-dev-key
VLLM_MODEL_NAME=qwen2.5-7b

# HuggingFace token (only for gated models)
HF_TOKEN=

# Paths
ALQAC_DATA_DIR=./Data
ALQAC_RUNS_DIR=./runs
